# Copy this file to .env and fill in real values. NEVER commit .env to git.

# --- App ---
ENV=development
SECRET_KEY=replace_with_a_long_random_string

# --- Database (SQLite default; swap for Postgres in production) ---
DATABASE_URL=sqlite:///pinforge.db
# DATABASE_URL=postgresql://user:password@host:5432/pinforge

# --- Pinterest Developer App (https://developers.pinterest.com/apps/) ---
PINTEREST_APP_ID=your_pinterest_app_id
PINTEREST_APP_SECRET=your_pinterest_app_secret
PINTEREST_REDIRECT_URI=http://localhost:8501

# --- AI content generation (Anthropic Claude) ---
ANTHROPIC_API_KEY=your_anthropic_api_key
AI_MODEL=claude-sonnet-4-6

# --- Safety limits (hard-capped server-side in config.py) ---
MAX_PINS_PER_ACCOUNT_PER_DAY=15
MIN_DELAY_MINUTES=15
MAX_DELAY_MINUTES=60

# --- Storage paths ---
UPLOAD_DIR=static/uploads
PROCESSED_DIR=static/processed
