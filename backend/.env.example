# ─── PinForge AI Backend — Environment Variables ───────────────────────────
# Copy to .env and fill in. NEVER commit .env to git.

ENV=development
FRONTEND_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────────────
# Settings → API in your Supabase project dashboard
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...   # service_role key (never expose to frontend)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Supabase PostgreSQL direct connection string
# Settings → Database → Connection String → URI (direct, not pooler, for SQLAlchemy)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Pinterest API v5 ─────────────────────────────────────────────────────────
# https://developers.pinterest.com/apps/
PINTEREST_APP_ID=your_app_id
PINTEREST_APP_SECRET=your_app_secret
# Must exactly match what you register in the Pinterest app settings
PINTEREST_REDIRECT_URI=http://localhost:8000/api/accounts/callback

# ── AI APIs ──────────────────────────────────────────────────────────────────
# Gemini (free tier): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# OpenAI (optional): https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Default provider for users who haven't set their own key
DEFAULT_AI_PROVIDER=gemini

# ── Safety Limits ─────────────────────────────────────────────────────────────
MAX_PINS_PER_ACCOUNT_PER_DAY=15
MIN_DELAY_MINUTES=15
MAX_DELAY_MINUTES=60

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=static/uploads
PROCESSED_DIR=static/processed
